NODE_ENV=development

POSTGRES_DB=rdat
POSTGRES_USER=rdat
POSTGRES_PASSWORD=rdat_dev_password
DATABASE_URL=postgres://rdat:rdat_dev_password@postgres:5432/rdat

REDIS_URL=redis://redis:6379

API_HOST=0.0.0.0
API_PORT=4000
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_CLIENTS=200
WORKER_CONCURRENCY=2
INGESTION_ENABLED=false
BASE_SEPOLIA_RPC_HTTP_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_WS_URL=
INGESTION_POLLING_INTERVAL_MS=2000
INGESTION_DEDUP_TTL_SECONDS=86400
MONITORED_POOLS=[]
# Example:
# MONITORED_POOLS=[{"address":"0x0000000000000000000000000000000000000000","protocol":"uniswap-v2","token0":"0x0000000000000000000000000000000000000000","token1":"0x0000000000000000000000000000000000000000","token0Symbol":"TOKEN0","token1Symbol":"TOKEN1"}]

NEXT_PUBLIC_API_URL=http://localhost:4000
